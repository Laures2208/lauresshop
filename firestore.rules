rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'balance', 'role']) &&
             data.username is string && data.username.size() <= 100 &&
             data.role is string &&
             data.balance is number &&
             (data.keys().hasAll(['email']) ? (data.email is string && data.email.size() <= 100) : true) &&
             (data.keys().hasAll(['phone']) ? (data.phone is string && data.phone.size() <= 20) : true) &&
             (data.keys().hasAll(['password']) ? (data.password is string && data.password.size() <= 100) : true);
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isValidId(userId) && 
                    isValidUser(incoming()) && 
                    incoming().balance == 0 &&
                    incoming().keys().hasOnly(['username', 'email', 'balance', 'phone', 'role', 'password']);
      allow update: if isValidId(userId) && 
                    isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['username', 'email', 'phone', 'balance', 'password']);
      allow delete: if isValidId(userId);
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'price', 'rank', 'gameUsername', 'gamePassword']);
    }

    match /accounts/{accountId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() <= 128 &&
             data.createdAt is number;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isValidId(categoryId) && isValidCategory(incoming());
      allow delete: if isValidId(categoryId);
    }
    
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'createdAt', 'paymentMethod']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.items is list &&
             data.totalAmount is number &&
             data.status is string &&
             data.createdAt is number &&
             data.paymentMethod is string &&
             (!data.keys().hasAll(['zaloPhone']) || (data.zaloPhone is string && data.zaloPhone.size() <= 50));
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow update: if isValidId(orderId) && isValidOrder(incoming());
      allow delete: if isValidId(orderId);
    }
    
    function isValidServicePrices(data) {
      return data.keys().hasAll(['rentPerHour', 'boostBasic', 'boostStar', 'boostCombo1', 'boostCombo2']) &&
             data.rentPerHour is number &&
             data.boostBasic is number &&
             data.boostStar is number &&
             data.boostCombo1 is number &&
             data.boostCombo2 is number &&
             data.keys().hasOnly(['rentPerHour', 'boostBasic', 'boostStar', 'boostCombo1', 'boostCombo2']);
    }

    match /settings/prices {
      allow read: if true;
      allow create: if isValidServicePrices(incoming());
      allow update: if isValidServicePrices(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['rentPerHour', 'boostBasic', 'boostStar', 'boostCombo1', 'boostCombo2']);
    }
  }
}

